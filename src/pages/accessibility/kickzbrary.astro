---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="KickzBrary"
  description="KickzBrary is currently in development."
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Coming Soon</p>

      <div class="page-app-icon">
        <img
          src="/icons/kickzbrary.png"
          alt="KickzBrary app icon"
          class="app-icon"
        />
      </div>
      <h1>KickzBrary</h1>

      <p>
        Organize your sneaker collection.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="content-card">
      <p>
        KickzBrary is currently in active development.
      </p>

      <p>
        I'm building an app for sneaker enthusiasts to catalog,
        organize, and explore their collections with a focus on
        privacy, performance, and a native Apple experience.
      </p>

      <p>
        Coming to Apple platforms.
      </p>

      <p style="margin-top: 2rem;">
        <a href="/apps">← Back to Apps</a>
      </p>
    </div>
  </section>
</BaseLayout>